# Auto-generated .dotinstall for TL40-Dots
# Generated: 2025-09-10
# Assumptions:
# - The dotfiles-installer consumes a YAML file with a top-level `dotfiles` list
#   where each item has `src`, `dest` and optional `method` ("symlink" or "copy").
# - If your installer expects a different schema, tell me and I'll adapt the file.

version: 1
description: "TL40-Dots - autogenerated mappings for dotfiles-installer"

dotfiles:
  - src: "bash/.bashrc"
    dest: "~/.bashrc"
    method: "symlink"

  - src: "git/.gitconfig"
    dest: "~/.gitconfig"
    method: "symlink"

  - src: ".config/kitty/kitty.conf"
    dest: "~/.config/kitty/kitty.conf"
    method: "symlink"

  - src: ".config/starship/.config/starship.toml"
    dest: "~/.config/starship.toml"
    method: "symlink"

  - src: ".config/atuin/config.toml"
    dest: "~/.config/atuin/config.toml"
    method: "symlink"

  - src: ".config/gSnap/layouts.json"
    dest: "~/.config/gSnap/layouts.json"
    method: "symlink"

  - src: ".config/guake/session.json"
    dest: "~/.config/guake/session.json"
    method: "symlink"

  - src: ".config/aichat/config.yaml"
    dest: "~/.config/aichat/config.yaml"
    method: "symlink"

  - src: ".config/burn-my-windows/profiles/1755598388870831.conf"
    dest: "~/.config/burn-my-windows/profiles/1755598388870831.conf"
    method: "symlink"

  - src: ".config/user-dirs.dirs"
    dest: "~/.config/user-dirs.dirs"
    method: "symlink"

  - src: "fav_themes"
    dest: "~/.local/share/fav_themes"
    method: "copy"

  - src: "system.yaml"
    dest: "~/.config/tl40/system.yaml"
    method: "copy"

post_install:
  # Example post-install command; keep or remove as needed
  - cmd: "mkdir -p ~/.config/kitty && echo 'installed TL40-Dots configs' > ~/.config/tl40/INSTALLATION_NOTE || true"

notes: |
  This file was generated from the repository contents.
  If your dotfiles-installer expects a different format (JSON, other keys, or
  supports template variables), tell me the required schema and I'll update
  this file accordingly. Also confirm whether you prefer symlinks or copies
  for specific entries (I used symlinks by default and copy for folders).
